{
    "name": "digital-inputs-detector",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",
                "anthropic.claude-code",
                "espressif.esp-idf-extension"
            ]
        }
    },
    "postCreateCommand": "echo 'export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:$PATH' >> ~/.bashrc && bash .devcontainer/install-esp-idf.sh",
    "runArgs": ["--privileged"],
    "mounts": [
        "source=${localEnv:USERPROFILE}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached"
    ]
}
